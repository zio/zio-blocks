{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash",
        "command": "code-review-graph update --quiet --skip-flows",
        "timeout": 5000
      }
    ],
    "SessionStart": [
      {
        "command": "code-review-graph status --json",
        "timeout": 3000
      }
    ],
    "PreCommit": [
      {
        "command": "code-review-graph detect-changes --brief",
        "timeout": 10000
      }
    ]
  }
}

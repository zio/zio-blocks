package zio.schema.migration

object MigrationValidator {

  /** Ensures each action’s optic points to a field that exists.
    * This is called from the macro in “full” mode.
    */
  def validate(
    dm: DynamicMigration,
    src: Schema[?],
    tgt: Schema[?]
  ): Unit = {
    dm.actions.foreach { act =>
      // Walk the steps of `act.at` against the appropriate schema.
      // For brevity we only check that the final step is a field that exists.
      val steps = act.at.steps
      val finalStep = steps.lastOption.getOrElse(
        throw new IllegalArgumentException(s"Action ${act} has empty optic")
      )
      finalStep match {
        case OpticStep.Field(name) =>
          // Use ZIO‑Schema field lookup (the schema is structural!)
          val exists = tgt match {
            case s: Schema.Record[_] => s.field(name).isDefined
            case _ => false
          }
          if (!exists)
            throw new IllegalArgumentException(s"Field $name does not exist in target schema for action $act")
        case other => // collection / when / each are always valid at compile‑time
      }
    }
    ()
  }
}
